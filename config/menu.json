{
  "version": "2.0.0",
  "ios_support": "16.0-26.5",
  "theme": {
    "name": "Cyber Neon Dark",
    "background_color": "#0A0A0F",
    "background_alpha": 0.97,
    "accent_color": "#00FFFF",
    "secondary_color": "#FF00FF",
    "text_color": "#FFFFFF",
    "danger_color": "#FF4444",
    "success_color": "#44FF44",
    "warning_color": "#FFAA00"
  },
  "sections": [
    {
      "id": "header",
      "title": "🔥 KENIOS HAX v4.5.0",
