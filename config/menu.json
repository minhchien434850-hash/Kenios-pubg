        {"type": "label", "text": "👤 Welcome", "key": "welcome"},
        {"type": "label", "text": "🛡 Anti-Ban: ACTIVE", "key": "antiband", "color": "#44FF44"},
        {"type": "label", "text": "📊 FPS: --", "key": "fps", "color": "#00FFFF"},
        {"type": "label", "text": "📡 Ping: --ms", "key": "ping", "color": "#FFAA00"},
        {"type": "label", "text": "📱 iOS: --", "key": "ios_version", "color": "#AAAAAA"},
        {"type": "button", "text": "⭐ GitHub", "action": "open_github"},
        {"type": "button", "text": "👁 Hide Menu", "action": "hide_menu", "color": "#FF4444"}
      ]
    },
    {
      "id": "aimbot",
